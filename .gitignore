# Laravel
/vendor/
/node_modules/
/public/build/
/public/hot
/public/storage
/storage/*.key
.env
.env.backup
.env.production
.phpunit.result.cache
Homestead.json
Homestead.yaml
auth.json
npm-debug.log
yarn-error.log

# IDE
/.idea
/.vscode
*.swp
*.swo
.DS_Store
_ide_helper.php
_ide_helper_models.php
.phpstorm.meta.php

# Logs
*.log
/storage/logs/*
!/storage/logs/.gitkeep

# Cache
/bootstrap/cache/*
!/bootstrap/cache/.gitkeep

# Compiled files
*.compiled.php

# Laravel Boost (auto-generated by boost:install / boost:update)
# NOTE: .cursor/mcp.json is committed (Docker-routed) and intentionally NOT ignored
/boost.json
/.mcp.json
/AGENTS.md
/CLAUDE.md

# Sitemaps (generated at runtime)
/public/sitemap*.xml

# Static site snapshots (generated by `php artisan site:build`)
/public/static/

# Docker volumes data
/data/
/logs/

# Database backups (db-backup sidecar writes here; ship offsite, don't commit)
/backups/

# Testing
/coverage
/.phpunit.cache

# OS
Thumbs.db
