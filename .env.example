# ==============================================
# Local Development Environment — __APP_NAME__
# Copy to .env and run `php artisan key:generate`.
# Values are tuned for the docker-compose.dev.yml stack.
# ==============================================

APP_NAME="__APP_NAME__"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8787

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# ==============================================
# PostgreSQL (db service in docker-compose.dev.yml)
# ==============================================
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=__APP_SLUG__
DB_USERNAME=__APP_SLUG__
DB_PASSWORD=changeme

# ==============================================
# Session / Cache / Queue
# No Redis service in the dev stack — use simple local drivers.
# ==============================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ==============================================
# Logging
# ==============================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==============================================
# Mail (logs to storage/logs in dev)
# ==============================================
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@__APP_DOMAIN__"
MAIL_FROM_NAME="${APP_NAME}"

# ==============================================
# Octane (FrankenPHP worker mode)
# ==============================================
OCTANE_SERVER=frankenphp
# Number of resident PHP worker threads (rule of thumb: 1-2x CPU cores).
# Must be >= 1; setting 0 does NOT disable worker mode (it falls back to
# the FrankenPHP default of 2x CPUs). To truly disable worker mode, remove
# the worker {} block from the Caddyfile.
FRANKENPHP_NUM_WORKERS=4
# Recycle a PHP thread after this many requests to mitigate memory creep.
# 0 = unlimited (never recycle by count).
FRANKENPHP_MAX_REQUESTS=500

# ==============================================
# Observability dashboards
# ==============================================
# Pulse  -> /pulse     (lightweight always-on performance dashboard)
# Telescope -> /telescope (detailed request/query/log/job inspector)
# In local both are accessible; in production they're gated off by default
# (see AppServiceProvider::authorizeDashboards).
PULSE_ENABLED=true
TELESCOPE_ENABLED=true

# ==============================================
# Anthropic (AI SEO content generation)
# Required only for `php artisan seo:generate-page-content`.
# ==============================================
ANTHROPIC_API_KEY=

# ==============================================
# Sentry (error tracking)
# ==============================================
# Leave the DSN empty in local so dev errors don't spam your Sentry project;
# Collision/Pail already surface them in the terminal.
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
