{
    frankenphp
    auto_https off
    servers {
        trusted_proxies static private_ranges
    }
}

:80 {
    root * /app/public
    encode zstd gzip

    @www host www.__APP_DOMAIN__
    redir @www https://__APP_DOMAIN__{uri} permanent

    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    @build path /build/*
    header @build Cache-Control "public, max-age=31536000, immutable"

    @static path *.ico *.woff *.woff2 *.ttf *.eot
    header @static Cache-Control "public, max-age=86400"

    @images path *.jpg *.jpeg *.png *.gif *.svg *.webp
    header @images Cache-Control "public, max-age=604800"

    php_server

    log {
        output file /var/log/caddy/access.log {
            roll_size 100mb
            roll_keep 5
        }
        format json
    }
}
