{
    frankenphp {
        worker {
            file /app/public/frankenphp-worker.php
            num {$FRANKENPHP_NUM_WORKERS:4}
        }
        max_requests {$FRANKENPHP_MAX_REQUESTS:500}
    }
    auto_https off
    servers {
        trusted_proxies static private_ranges
    }
}

:80 {
    root * /app/public
    encode zstd gzip

    @www host www.__APP_DOMAIN__
    redir @www https://__APP_DOMAIN__{uri} permanent

    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    @build path /build/*
    header @build Cache-Control "public, max-age=31536000, immutable"

    @static path *.ico *.woff *.woff2 *.ttf *.eot
    header @static Cache-Control "public, max-age=86400"

    @images path *.jpg *.jpeg *.png *.gif *.svg *.webp
    header @images Cache-Control "public, max-age=604800"

    # Keep the Pulse/Telescope dashboards off the public internet. The Cloudflare
    # tunnel forwards the real domain as the Host header, so 404 those paths when
    # requested via the domain. They remain reachable over the VPN through an SSH
    # port-forward to 127.0.0.1:80 (Host = localhost). The Laravel gate in
    # AppServiceProvider enforces the same rule as a backstop.
    @public_dash {
        path /pulse* /telescope*
        host __APP_DOMAIN__ www.__APP_DOMAIN__
    }
    route {
        respond @public_dash 404

        # Static site snapshots (php artisan site:build) live under
        # public/static/{domain}/... — serve them directly so PHP never runs
        # for a cached page. Falls through to php_server on a miss, which
        # renders the same page dynamically.
        @sitecache {
            method GET
            file {
                try_files /static/{host}{path}/index.html /static/{host}{path}index.html /static/{host}{path}
            }
        }
        header @sitecache Cache-Control "public, max-age=300"
        rewrite @sitecache {http.matchers.file.relative}

        php_server
    }

    log {
        output file /var/log/caddy/access.log {
            roll_size 100mb
            roll_keep 5
        }
        format json
    }
}
