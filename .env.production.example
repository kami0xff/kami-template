# ==============================================
# Production Environment — __APP_NAME__
# Copy to .env.production and fill in values
# ==============================================

APP_NAME="__APP_NAME__"
APP_ENV=production
APP_KEY=  # Generate: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://__APP_DOMAIN__

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# ==============================================
# PostgreSQL Database
# ==============================================
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=__APP_SLUG__
DB_USERNAME=__APP_SLUG__
DB_PASSWORD=  # Generate a strong password

# Optional read-only connection (replica / shared admin DB) used by Query
# classes via ->on('read'). Falls back to the main connection when unset.
# DB_READ_HOST=
# DB_READ_PORT=5432
# DB_READ_DATABASE=
# DB_READ_USERNAME=
# DB_READ_PASSWORD=

# ==============================================
# Session, Cache & Queue
# ==============================================
# IMPORTANT: Redis here is an EVICTABLE cache (maxmemory + allkeys-lru), so it
# must NOT hold durable data. Sessions and the queue live in Postgres so they
# can never be silently evicted (which would log users out / drop jobs).
# Cache -> redis (fast, evictable). Sessions + queue -> database (durable).
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=__APP_DOMAIN__
SESSION_SECURE_COOKIE=true

CACHE_STORE=redis
QUEUE_CONNECTION=database

# ==============================================
# Redis (cache only)
# ==============================================
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==============================================
# Logging
# ==============================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ==============================================
# Security
# ==============================================
BCRYPT_ROUNDS=12

# ==============================================
# Mail (Optional)
# ==============================================
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@__APP_DOMAIN__
MAIL_FROM_NAME="${APP_NAME}"

# ==============================================
# Filesystem
# ==============================================
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# ==============================================
# Octane (FrankenPHP worker mode)
# ==============================================
OCTANE_SERVER=frankenphp
# Number of resident PHP worker threads (rule of thumb: 1-2x CPU cores).
# Keep >= 1. The Caddyfile reads this; 0 does NOT disable worker mode.
# For best stability keep FRANKENPHP_NUM_WORKERS x memory_limit < available RAM.
FRANKENPHP_NUM_WORKERS=4
# Recycle a PHP thread after this many requests to mitigate memory creep.
# 0 = unlimited (never recycle by count).
FRANKENPHP_MAX_REQUESTS=500

# ==============================================
# Observability dashboards
# ==============================================
# Pulse -> /pulse: lightweight, production-safe; leave enabled.
# Telescope -> /telescope: records a LOT (every request/query/job). Keep OFF in
# production; flip to true only while actively debugging, then turn it back off.
# ACCESS: both dashboards 404 on the public domain (Caddyfile) and are blocked
# by the gate unless the Host is localhost. Reach them over the VPN with an SSH
# port-forward, then browse http://localhost:8080/pulse :
#   ssh -L 8080:127.0.0.1:80 youruser@yourserver
PULSE_ENABLED=true
TELESCOPE_ENABLED=false

# ==============================================
# Sentry (error tracking)
# ==============================================
# Paste the DSN from your Sentry project (Settings -> Client Keys (DSN)).
# Captures exceptions from web + worker + scheduler automatically.
SENTRY_LARAVEL_DSN=
# Performance tracing sample rate: 0.0 = errors only (no perf overhead/quota).
# Raise to e.g. 0.2 to sample 20% of requests as performance transactions.
SENTRY_TRACES_SAMPLE_RATE=0.0
# Don't attach user PII (IP, cookies) to events unless you need it.
SENTRY_SEND_DEFAULT_PII=false

# ==============================================
# Umami analytics (cookieless, no consent banner needed)
# Main app website id; static sites set their own in site.php.
# Default src is Umami Cloud — set UMAMI_SRC for self-hosted.
# ==============================================
UMAMI_WEBSITE_ID=
#UMAMI_SRC=https://analytics.example.com/script.js

# ==============================================
# OpenReplay (session recording) — opt-in, off by default.
# Setting the key alone does nothing; flip OPENREPLAY_ENABLED=true
# on the specific project where you actually want session recording.
# ==============================================
OPENREPLAY_ENABLED=false
OPENREPLAY_PROJECT_KEY=  # Get from app.openreplay.com

# ==============================================
# Static Sites (multi-domain hosting)
# Opt-in: set true to serve the sites under resources/sites/. deploy.sh
# builds their static snapshots automatically when enabled.
# ==============================================
SITES_ENABLED=false

# ==============================================
# Leads (static site forms -> admin project API)
# Form submissions on static sites POST to /lead and are relayed to this
# endpoint by the queue worker, signed with HMAC-SHA256 of the JSON body
# using the secret (verify it in the admin project — snippet in README).
# Leave the URL empty to park leads in storage/app/leads.jsonl instead.
# ==============================================
LEADS_WEBHOOK_URL=
LEADS_WEBHOOK_SECRET=  # Generate: openssl rand -hex 32 (same value in the admin project)

# ==============================================
# Anthropic (AI content generation)
# Required for `php artisan seo:generate-page-content` and `site:write`.
# ==============================================
ANTHROPIC_API_KEY=

